PORT=3000
DATABASE=./database.sqlite

# Публічна адреса сервера - заповнюється ПІСЛЯ першого деплою на Render
# (напр. https://e-bike-rental.onrender.com, без слеша в кінці).
# Потрібна для коректних return_url/cancel_url у PayPal.
BASE_URL=

# PAYPAL
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox

# TWILIO (залишити пустим, якщо не потрібно)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

JWT_SECRET=your-super-secret-key-change-in-production
